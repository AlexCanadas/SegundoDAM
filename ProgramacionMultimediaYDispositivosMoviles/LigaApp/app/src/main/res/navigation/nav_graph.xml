<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/loginFragment">

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.example.ligaapp.LoginFragment"
        android:label="Login">

        <action
            android:id="@+id/action_login_to_register"
            app:destination="@id/registerFragment" />

        <action
            android:id="@+id/action_login_to_ligas"
            app:destination="@id/ligasFragment" />

    </fragment>

    <fragment
        android:id="@+id/registerFragment"
        android:name="com.example.ligaapp.RegisterFragment"
        android:label="Registro" />

    <fragment
        android:id="@+id/ligasFragment"
        android:name="com.example.ligaapp.LigasFragment"
        android:label="Ligas">

        <action
            android:id="@+id/action_ligas_to_equipos"
            app:destination="@id/equiposFragment" />

    </fragment>

    <fragment
        android:id="@+id/equiposFragment"
        android:name="com.example.ligaapp.EquiposFragment"
        android:label="Equipos">

        <argument
            android:name="ligaNombre"
            app:argType="string" />

    </fragment>

    <fragment
        android:id="@+id/favoritosFragment"
        android:name="com.example.ligaapp.FavoritosFragment"
        android:label="Favoritos" />

</navigation>
